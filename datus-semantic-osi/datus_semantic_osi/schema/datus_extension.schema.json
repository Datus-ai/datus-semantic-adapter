{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://datus.ai/schemas/osi/datus_extension.schema.json",
  "title": "Datus OSI Extension",
  "description": "Backend-agnostic Datus business hints carried in OSI custom_extensions (vendor_name: DATUS). The LLM authors these; the Datus OSI compiler consumes them. No execution-engine syntax appears here.",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "metric_kind": {
      "description": "Business kind of the metric. Only required when the compiler cannot safely infer it.",
      "type": "string",
      "enum": ["aggregate", "expression", "ratio", "cumulative", "derived"]
    },
    "metric_type": {
      "description": "Compatibility alias for metric_kind.",
      "type": "string",
      "enum": ["aggregate", "expression", "ratio", "cumulative", "derived"]
    },
    "inputs": {
      "description": "Structured declaration of input fields, measures, or metrics.",
      "type": "array",
      "items": {
        "oneOf": [
          {"type": "string"},
          {
            "type": "object",
            "required": ["name"],
            "additionalProperties": false,
            "properties": {
              "name": {"type": "string"},
              "alias": {"type": "string"},
              "offset_window": {"type": "string"}
            }
          }
        ]
      }
    },
    "dataset": {"description": "Dataset that anchors a metric.", "type": "string"},
    "source_type": {"description": "How to interpret the OSI core dataset source string.", "type": "string", "enum": ["table", "query"]},
    "numerator": {"description": "Ratio numerator semantic input.", "type": "string"},
    "denominator": {"description": "Ratio denominator semantic input.", "type": "string"},
    "window": {"description": "Cumulative window, e.g. '7 days'.", "type": "string"},
    "grain_to_date": {"description": "Cumulative grain, e.g. 'month'.", "type": "string"},
    "offset_window": {"description": "Comparison window for YoY / MoM / prior-period.", "type": "string"},
    "time_dimension": {
      "description": "Time dimension used for aggregation/accumulation.",
      "oneOf": [
        {"type": "string"},
        {
          "type": "object",
          "required": ["name"],
          "properties": {
            "name": {"type": "string"},
            "granularity": {"type": "string"}
          },
          "additionalProperties": false
        }
      ]
    },
    "time_granularity": {
      "description": "Query/field time granularity.",
      "type": "string",
      "enum": ["day", "week", "month", "quarter", "year"]
    },
    "filter": {"$ref": "#/$defs/filter"},
    "filters": {"type": "array", "items": {"$ref": "#/$defs/filter"}},
    "subject_path": {
      "description": "Datus metric catalog hierarchy.",
      "type": "array",
      "items": {"type": "string"}
    },
    "format": {"description": "Display format, e.g. '0.00%'.", "type": "string"},
    "unit": {"description": "Business unit.", "type": "string"}
  },
  "$defs": {
    "filter": {
      "type": "object",
      "required": ["expression"],
      "properties": {
        "name": {"type": "string"},
        "expression": {"type": "string"},
        "scope": {"type": "string", "enum": ["dataset", "measure", "metric"]}
      }
    }
  }
}
